# Policy-intel production defaults
# Copy to .env.policy-intel.prod and fill locally. Never commit secrets.
#
# Key signup references: see .env.policy-intel.example header comments.

NODE_ENV=production
POLICY_INTEL_PORT=5050
POLICY_INTEL_HOST_PORT=5050
SESSION_SECRET=replace-with-a-long-random-secret
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/actup_policy_intel
POLICY_INTEL_API_TOKEN=replace-with-a-long-random-token
POLICY_INTEL_MIGRATION_APPROVED=no
POLICY_INTEL_BACKUP_ID=

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
LEGISCAN_API_KEY=
LEGISCAN_DETAIL_CONCURRENCY=6
CONGRESS_API_KEY=
OPENSTATES_API_KEY=
FEC_API_KEY=
PROPUBLICA_API_KEY=
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

SLACK_WEBHOOK_URL=

{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ScoutBotProfileQueue",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "format": "uuid"
    },
    "name": {
      "type": "string"
    },
    "type": {
      "type": "string",
      "enum": [
        "consultant",
        "influencer",
        "strategist",
        "corporate"
      ]
    },
    "source_urls": {
      "type": "array",
      "items": {
        "type": "string",
        "format": "uri"
      }
    },
    "summary": {
      "type": "string"
    },
    "affiliations": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "organization": {
            "type": "string"
          },
          "role": {
            "type": "string"
          },
          "dates": {
            "type": "string"
          }
        },
        "required": [
          "organization",
          "role"
        ]
      }
    },
    "media_mentions": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "headline": {
            "type": "string"
          },
          "source": {
            "type": "string"
          },
          "url": {
            "type": "string",
            "format": "uri"
          },
          "date": {
            "type": "string",
            "format": "date"
          }
        },
        "required": [
          "headline",
          "source",
          "url"
        ]
      }
    },
    "influence_topics": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "status": {
      "type": "string",
      "enum": [
        "pending",
        "approved",
        "rejected"
      ],
      "default": "pending"
    },
    "submitted_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "required": [
    "id",
    "name",
    "type",
    "source_urls",
    "status",
    "submitted_at"
  ]
}
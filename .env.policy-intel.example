# Local policy-intel — TEMPLATE ONLY (safe to commit)
#
# Docker loads ONLY ".env.policy-intel" (not this file).
# First run:  npm run policy-intel:env
# Then open .env.policy-intel and paste your real keys there.
#
# Get keys:
#   LegiScan:  https://legiscan.com/legiscan
#   OpenStates: https://openstates.org/accounts/profile/
#   OpenAI:    https://platform.openai.com/api-keys
#   Anthropic: https://console.anthropic.com/

NODE_ENV=development
POLICY_INTEL_PORT=5050
SESSION_SECRET=change-me-in-local-dev
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/actup_policy_intel
VITE_API_PROXY_TARGET=http://policy-intel:5050
CHOKIDAR_USEPOLLING=true

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
LEGISCAN_API_KEY=
LEGISCAN_DETAIL_CONCURRENCY=6
OPENSTATES_API_KEY=

# Leave blank for local dev (no login required). Set in production.
POLICY_INTEL_API_TOKEN=

# Optional
SLACK_WEBHOOK_URL=

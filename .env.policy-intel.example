# Local policy-intel development
# Copy to .env.policy-intel and fill in locally. Never commit real secrets.
#
# Where to obtain keys (official / primary sources):
# - LegiScan:        https://legiscan.com/legiscan (API subscription)
# - Open States:     https://openstates.org/accounts/profile/ (API key)
# - Congress.gov:    https://api.congress.gov/sign-up/
# - OpenFEC:         https://api.open.fec.gov/developers/
# - ProPublica:      https://www.propublica.org/datastore/api/propublica-congress-api
# - OpenAI:          https://platform.openai.com/api-keys
# - Anthropic:       Settings → API keys in https://console.anthropic.com/
# - Slack webhook:   https://api.slack.com/messaging/webhooks
# - AWS IAM:         https://console.aws.amazon.com/iam/ (only if you add S3/storage later)

NODE_ENV=development
POLICY_INTEL_PORT=5050
# Unused by policy-intel server today; kept for parity with other stacks.
SESSION_SECRET=change-me-in-local-dev
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/actup_policy_intel
VITE_API_PROXY_TARGET=http://policy-intel:5050
CHOKIDAR_USEPOLLING=true

# Optional integrations
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
LEGISCAN_API_KEY=
LEGISCAN_DETAIL_CONCURRENCY=6
CONGRESS_API_KEY=
OPENSTATES_API_KEY=
FEC_API_KEY=
PROPUBLICA_API_KEY=
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Auth — set to enable bearer-token API protection (leave blank for open access)
POLICY_INTEL_API_TOKEN=

# Slack — incoming webhook URL for alert notifications
SLACK_WEBHOOK_URL=

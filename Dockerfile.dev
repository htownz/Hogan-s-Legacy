FROM alpine:3.23

RUN apk upgrade --no-cache \
    && apk add --no-cache \
    nodejs \
    npm \
    ca-certificates \
    ffmpeg \
    postgresql-client

WORKDIR /workspace

COPY package*.json ./
RUN npm ci

COPY docker-entrypoint.sh /usr/local/bin/docker-entrypoint.sh
RUN chmod +x /usr/local/bin/docker-entrypoint.sh

COPY . .

EXPOSE 5050
ENTRYPOINT ["docker-entrypoint.sh"]
CMD ["npm", "run", "dev:policy-intel"]

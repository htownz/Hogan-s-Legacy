FROM node:20-bookworm-slim

RUN apt-get update \
    && apt-get install -y --no-install-recommends \
       bash \
       curl \
       git \
       ca-certificates \
       postgresql-client \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /workspace

COPY package*.json ./
RUN npm ci

COPY . .

EXPOSE 5050
CMD ["npm", "run", "dev:policy-intel"]

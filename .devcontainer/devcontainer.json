{
  "name": "ActUp Policy Intel",
  "dockerComposeFile": [
    "../docker-compose.policy-intel.yml"
  ],
  "service": "policy-intel",
  "workspaceFolder": "/workspace",
  "shutdownAction": "none",
  "forwardPorts": [5050, 5173, 5433, 8080],
  "postCreateCommand": "npm install && npm run db:push:policy-intel",
  "customizations": {
    "vscode": {
      "settings": {
        "editor.formatOnSave": true,
        "remote.extensionKind": {
          "github.copilot-chat": [
            "ui"
          ]
        },
        "files.exclude": {
          "**/.turbo": true,
          "**/dist": true
        }
      },
      "extensions": [
        "ms-vscode.vscode-typescript-next",
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "ms-azuretools.vscode-docker",
        "ms-vscode-remote.remote-containers",
        "mtxr.sqltools",
        "mtxr.sqltools-driver-pg"
      ]
    }
  }
}

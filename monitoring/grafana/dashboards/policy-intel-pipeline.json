{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Service Uptime",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "policy_intel_uptime_seconds",
          "legendFormat": "Uptime"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 300 },
              { "color": "green", "value": 3600 }
            ]
          }
        }
      }
    },
    {
      "title": "Pipeline Runs (Rate)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "targets": [
        {
          "expr": "rate(policy_intel_pipeline_runs_total[5m])",
          "legendFormat": "runs/s"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 100 }
            ]
          }
        }
      }
    },
    {
      "title": "Alerts Created (Total)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "targets": [
        {
          "expr": "policy_intel_alerts_created_total",
          "legendFormat": "total"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null }
            ]
          }
        }
      }
    },
    {
      "title": "Current Regime",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "policy_intel_regime_current == 1",
          "legendFormat": "{{regime}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [{ "type": "value", "options": { "1": { "text": "Active" } } }],
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "purple", "value": null }]
          }
        }
      }
    },
    {
      "title": "Docs Processed vs Matched",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 0 },
      "targets": [
        {
          "expr": "policy_intel_docs_processed_total",
          "legendFormat": "Processed"
        },
        {
          "expr": "policy_intel_docs_matched_total",
          "legendFormat": "Matched"
        }
      ]
    },
    {
      "title": "HTTP Request Rate",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(policy_intel_http_requests_total[5m]))",
          "legendFormat": "req/s"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        }
      }
    },
    {
      "title": "Pipeline Actions Over Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "targets": [
        {
          "expr": "rate(policy_intel_pipeline_actions_total{action=\"escalate\"}[5m])",
          "legendFormat": "Escalate"
        },
        {
          "expr": "rate(policy_intel_pipeline_actions_total{action=\"watch\"}[5m])",
          "legendFormat": "Watch"
        },
        {
          "expr": "rate(policy_intel_pipeline_actions_total{action=\"archive\"}[5m])",
          "legendFormat": "Archive"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "fillOpacity": 20, "stacking": { "mode": "normal" } }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Escalate" }, "properties": [{ "id": "color", "value": { "fixedColor": "red" } }] },
          { "matcher": { "id": "byName", "options": "Watch" }, "properties": [{ "id": "color", "value": { "fixedColor": "yellow" } }] },
          { "matcher": { "id": "byName", "options": "Archive" }, "properties": [{ "id": "color", "value": { "fixedColor": "green" } }] }
        ]
      }
    },
    {
      "title": "Pipeline Score Distribution",
      "type": "histogram",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "targets": [
        {
          "expr": "policy_intel_pipeline_score_bucket",
          "legendFormat": "{{le}}",
          "format": "heatmap"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "scheme", "schemeId": "RdYlGn" }
        }
      }
    },
    {
      "title": "Agent Scores (Avg over 5m)",
      "type": "bargauge",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "targets": [
        {
          "expr": "rate(policy_intel_agent_score_sum[5m]) / rate(policy_intel_agent_score_count[5m])",
          "legendFormat": "{{agent}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null },
              { "color": "yellow", "value": 0.4 },
              { "color": "orange", "value": 0.6 },
              { "color": "red", "value": 0.8 }
            ]
          }
        }
      }
    },
    {
      "title": "Regime Detections Over Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "targets": [
        {
          "expr": "rate(policy_intel_regime_detections_total[5m])",
          "legendFormat": "{{regime}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "fillOpacity": 30, "stacking": { "mode": "normal" } }
        }
      }
    },
    {
      "title": "Pipeline Confidence Distribution",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(policy_intel_pipeline_confidence_bucket[5m]))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.90, rate(policy_intel_pipeline_confidence_bucket[5m]))",
          "legendFormat": "p90"
        },
        {
          "expr": "histogram_quantile(0.99, rate(policy_intel_pipeline_confidence_bucket[5m]))",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "title": "Alerts Created vs Skipped",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "targets": [
        {
          "expr": "rate(policy_intel_alerts_created_total[5m])",
          "legendFormat": "Created"
        },
        {
          "expr": "rate(policy_intel_alerts_skipped_total{reason=\"duplicate\"}[5m])",
          "legendFormat": "Skipped (dup)"
        },
        {
          "expr": "rate(policy_intel_alerts_skipped_total{reason=\"cooldown\"}[5m])",
          "legendFormat": "Skipped (cooldown)"
        }
      ],
      "fieldConfig": {
        "overrides": [
          { "matcher": { "id": "byName", "options": "Created" }, "properties": [{ "id": "color", "value": { "fixedColor": "green" } }] },
          { "matcher": { "id": "byName", "options": "Skipped (dup)" }, "properties": [{ "id": "color", "value": { "fixedColor": "orange" } }] },
          { "matcher": { "id": "byName", "options": "Skipped (cooldown)" }, "properties": [{ "id": "color", "value": { "fixedColor": "red" } }] }
        ]
      }
    },
    {
      "title": "Pipeline Execution Time (ms)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 28 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(policy_intel_pipeline_duration_ms_bucket[5m]))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, rate(policy_intel_pipeline_duration_ms_bucket[5m]))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, rate(policy_intel_pipeline_duration_ms_bucket[5m]))",
          "legendFormat": "p99"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms"
        }
      }
    },
    {
      "title": "HTTP Latency (p50 / p95 / p99)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 28 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(policy_intel_http_duration_ms_bucket[5m]))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, rate(policy_intel_http_duration_ms_bucket[5m]))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, rate(policy_intel_http_duration_ms_bucket[5m]))",
          "legendFormat": "p99"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms"
        }
      }
    }
  ],
  "schemaVersion": 39,
  "tags": ["policy-intel", "agent-pipeline"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Policy Intel — Agent Pipeline",
  "uid": "policy-intel-pipeline",
  "version": 1,
  "refresh": "10s"
}

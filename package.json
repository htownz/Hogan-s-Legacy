{
  "name": "rest-express",
  "version": "1.0.0",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "dev": "tsx server/index.ts",
    "build": "vite build && esbuild server/index.ts --platform=node --packages=external --bundle --format=esm --outdir=dist && node -e \"const fs=require('fs');fs.copyFileSync('server/tecProcessor.js','dist/tecProcessor.js');\"",
    "start": "NODE_ENV=production node dist/index.js",
    "check": "tsc",
    "db:push": "drizzle-kit push",
    "dev:policy-intel": "tsx watch server/policy-intel/index.ts",
    "dev:policy-intel:container": "tsx server/policy-intel/index.ts",
    "start:policy-intel": "node --enable-source-maps dist-policy-intel/index.js",
    "build:policy-intel": "esbuild server/policy-intel/index.ts --platform=node --packages=external --bundle --format=esm --outdir=dist-policy-intel",
    "policy-intel:env": "node scripts/setup-policy-intel-env.mjs",
    "db:migrate:policy-intel": "drizzle-kit migrate --config=drizzle.policy-intel.config.ts",
    "db:push:policy-intel": "drizzle-kit push --config=drizzle.policy-intel.config.ts",
    "policy-intel:prod:up": "docker compose --env-file .env.policy-intel.prod -p hoganlegacy-prod -f docker-compose.policy-intel.prod.yml up --build -d",
    "policy-intel:prod:down": "docker compose --env-file .env.policy-intel.prod -p hoganlegacy-prod -f docker-compose.policy-intel.prod.yml down",
    "policy-intel:prod:ps": "docker compose --env-file .env.policy-intel.prod -p hoganlegacy-prod -f docker-compose.policy-intel.prod.yml ps",
    "policy-intel:prod:logs": "docker compose --env-file .env.policy-intel.prod -p hoganlegacy-prod -f docker-compose.policy-intel.prod.yml logs --tail=200 policy-intel-migrate policy-intel",
    "policy-intel:prod:migrate": "docker compose --env-file .env.policy-intel.prod -p hoganlegacy-prod -f docker-compose.policy-intel.prod.yml run --rm policy-intel-migrate",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },

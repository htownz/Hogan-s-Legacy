FROM node:22.22.2-alpine3.22

RUN apk upgrade --no-cache

RUN addgroup -g 1001 appgroup && adduser -S -u 1001 -G appgroup -s /bin/sh appuser

WORKDIR /workspace/client-policy-intel

COPY package*.json ./
RUN npm ci

COPY --chown=appuser:appgroup . .

USER appuser

EXPOSE 5173
CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0"]